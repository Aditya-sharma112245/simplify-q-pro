# ============================================================
# Lead Automation System — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ── Anthropic (Required) ─────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Email / SMTP (Required for email delivery) ───────────────
# For Gmail: use an App Password (not your main password)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
FROM_NAME=Intelligence Team
FROM_EMAIL=your_email@gmail.com

# ── Google Sheets (BONUS — optional) ────────────────────────
# Create a Service Account in GCP → download JSON → set path here
# Share the spreadsheet with the service account email
GOOGLE_CREDENTIALS_FILE=google_credentials.json
GOOGLE_SHEET_ID=your_google_sheet_id_here

# ── Google Drive (BONUS — optional) ─────────────────────────
# Same service account JSON. Share the Drive folder with service account.
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here

# ── Server Config (optional) ─────────────────────────────────
PORT=8000
HOST=0.0.0.0
